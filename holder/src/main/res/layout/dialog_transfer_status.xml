<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/transferIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:src="@android:drawable/stat_sys_data_bluetooth"
        app:tint="@color/blue" />

    <TextView
        android:id="@+id/transferTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Transfer in Progress"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/transferStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:text="Waiting for connection..."
        android:textSize="14sp"
        android:textColor="#666666" />

    <ProgressBar
        android:id="@+id/transferProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/transferPercent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:text="0%"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/transferInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Keep devices close together during transfer.\n\nBluetooth transfers may take a few seconds."
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center" />

</LinearLayout>

