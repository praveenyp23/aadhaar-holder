<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="mDoc Verifier"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Transfer Method"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- NFC Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/nfcButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Read via NFC"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            app:icon="@android:drawable/ic_menu_upload"
            app:iconGravity="textStart" />

        <!-- BLE Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/bleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Read via Bluetooth"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            app:icon="@android:drawable/stat_sys_data_bluetooth"
            app:iconGravity="textStart" />

        <!-- QR Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/qrButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan QR Code"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Parse Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/parseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Parse Claims"
            android:textSize="16sp"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            app:icon="@android:drawable/ic_menu_view"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.TonalButton" />

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status:"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to read"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Data Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Received Data:"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/dataText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No data yet"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>



